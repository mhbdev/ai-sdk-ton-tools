# Core runtime
BOT_PORT=8787
BOT_RUN_MODE=webhook
TELEGRAM_POLLING_TIMEOUT_SECONDS=10
TELEGRAM_POLLING_LIMIT=100
LOG_LEVEL=info
LOG_PRETTY=0
AI_MODEL=openai/gpt-5.2
AI_TOPIC_MODEL=openai/gpt-4o-mini
TELEGRAM_ENABLE_STREAM_DRAFTS=0
TOPIC_AUTOCREATE_ENABLED=1
APP_BASE_URL=https://bot.example.com
TONCONNECT_MANIFEST_URL=https://bot.example.com/tonconnect-manifest.json
KMS_KEY_ID=projects/your-project/locations/global/keyRings/ton-bot/cryptoKeys/app
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# Telegram and TON credentials
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_WEBHOOK_SECRET=replace_me
BOT_ADMIN_TOKEN=replace_me
TONAPI_API_KEY=replace_me
OPENROUTER_API_KEY=replace_me
# Optional: set to enable AI Gateway fallback provider
AI_GATEWAY_API_KEY=
ENCRYPTION_MASTER_KEY=replace_with_32_byte_base64
AI_GATEWAY_FALLBACK_MODEL=

# Postgres service credentials
POSTGRES_DB=telegram_bot
POSTGRES_USER=telegram_bot
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_URL=postgres://telegram_bot:change-this-db-password@postgres:5432/telegram_bot

# Redis credentials
REDIS_PASSWORD=change-this-redis-password
REDIS_URL=redis://:change-this-redis-password@redis:6379/0

# Optional observability profile
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password
GRAFANA_ROOT_URL=https://grafana.example.com

# Optional backup profile
POSTGRES_BACKUP_SCHEDULE=@daily
POSTGRES_BACKUP_KEEP_DAYS=14
POSTGRES_BACKUP_KEEP_WEEKS=8
POSTGRES_BACKUP_KEEP_MONTHS=12

# Optional secret file pattern:
# TELEGRAM_BOT_TOKEN_FILE=/run/secrets/telegram_bot_token
# OPENROUTER_API_KEY_FILE=/run/secrets/openrouter_api_key
# AI_GATEWAY_API_KEY_FILE=/run/secrets/ai_gateway_api_key
# TONAPI_API_KEY_FILE=/run/secrets/tonapi_api_key

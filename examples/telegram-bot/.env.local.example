NODE_ENV=development

TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_WEBHOOK_SECRET=local-dev-webhook-secret
BOT_RUN_MODE=polling
BOT_ADMIN_TOKEN=local-dev-admin-token

TONAPI_API_KEY=replace_me
OPENROUTER_API_KEY=replace_me
# Optional: set to enable AI Gateway fallback provider
AI_GATEWAY_API_KEY=
AI_MODEL=openai/gpt-5.2
AI_GATEWAY_FALLBACK_MODEL=

POSTGRES_URL=postgres://telegram_bot:telegram-bot-local-postgres@localhost:5432/telegram_bot
REDIS_URL=redis://:telegram-bot-local-redis@localhost:6379/0

KMS_KEY_ID=local-dev-key
ENCRYPTION_MASTER_KEY=replace_with_32_byte_base64
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

APP_BASE_URL=http://localhost:8787
TONCONNECT_MANIFEST_URL=http://localhost:8787/tonconnect-manifest.json

{
  "name": "telegram-ton-agent-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@ai-sdk/gateway": "2.0.0-beta.85",
    "@mhbdev/ai-sdk-ton-tools": "^0.1.0",
    "@openrouter/ai-sdk-provider": "^2.0.0",
    "ai": "6.0.0-beta.159",
    "bullmq": "^5.61.0",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.6.2",
    "grammy": "^1.38.3",
    "ioredis": "^5.8.2",
    "postgres": "^3.4.8",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.4",
    "drizzle-kit": "^0.31.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.12.3"
}

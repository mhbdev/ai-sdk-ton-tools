LOG_LEVEL=info
LOG_PRETTY=0

TELEGRAM_BOT_TOKEN=****
TELEGRAM_WEBHOOK_SECRET=****
BOT_RUN_MODE=webhook
TELEGRAM_POLLING_TIMEOUT_SECONDS=10
TELEGRAM_POLLING_LIMIT=100
BOT_ADMIN_TOKEN=****

TONAPI_API_KEY=****
OPENROUTER_API_KEY=****
# Optional: set to enable AI Gateway fallback provider
AI_GATEWAY_API_KEY=
AI_MODEL=openai/gpt-5.2
AI_GATEWAY_FALLBACK_MODEL=
AI_TOPIC_MODEL=openai/gpt-4o-mini
TELEGRAM_ENABLE_STREAM_DRAFTS=0
TOPIC_AUTOCREATE_ENABLED=1

POSTGRES_URL=****
REDIS_URL=redis://localhost:6379

KMS_KEY_ID=local-dev-key
ENCRYPTION_MASTER_KEY=****  # 32-byte base64 for local envelope encryption fallback
OTEL_EXPORTER_OTLP_ENDPOINT=

APP_BASE_URL=https://your-domain.example
TONCONNECT_MANIFEST_URL=https://your-domain.example/tonconnect-manifest.json
